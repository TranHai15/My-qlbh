<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" prefWidth="600.0" prefHeight="500.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grocerypos.ui.controllers.pos.CustomerSearchController" style="-fx-background-color: white;">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>

    <Label text="TÌM KIẾM / ĐĂNG KÝ KHÁCH HÀNG">
        <font><Font name="System Bold" size="18.0"/></font>
    </Label>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Nhập tên hoặc số điện thoại..." HBox.hgrow="ALWAYS" prefHeight="35.0" style="-fx-font-size: 14px;"/>
        <Button text="Tìm kiếm" onAction="#handleSearch" prefHeight="35.0" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" text="Tên khách hàng" prefWidth="200.0"/>
            <TableColumn fx:id="colPhone" text="Số điện thoại" prefWidth="150.0"/>
            <TableColumn fx:id="colPoints" text="Điểm tích lũy" prefWidth="120.0"/>
        </columns>
    </TableView>

    <Separator />
    
    <VBox spacing="5.0">
        <Label text="Đăng ký khách hàng mới nhanh:">
            <font><Font name="System Italic" size="12.0"/></font>
        </Label>
        <HBox spacing="10.0">
            <TextField fx:id="newNameField" promptText="Họ và tên..." HBox.hgrow="ALWAYS" prefHeight="35.0"/>
            <TextField fx:id="newPhoneField" promptText="Số điện thoại..." HBox.hgrow="ALWAYS" prefHeight="35.0"/>
            <Button text="+ THÊM MỚI" onAction="#handleQuickAdd" prefHeight="35.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Hủy bỏ" onAction="#handleCancel" prefWidth="100.0" prefHeight="35.0"/>
        <Button text="CHỌN KHÁCH HÀNG (Enter)" onAction="#handleSelect" prefWidth="220.0" prefHeight="35.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
