<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grocerypos.ui.controllers.pos.CustomerSearchController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Nhập tên hoặc số điện thoại..." HBox.hgrow="ALWAYS" />
        <Button text="Tìm kiếm" onAction="#onSearch" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS" prefHeight="300.0">
        <columns>
            <TableColumn fx:id="colName" text="Tên khách hàng" prefWidth="180.0"/>
            <TableColumn fx:id="colPhone" text="Số điện thoại" prefWidth="120.0"/>
            <TableColumn fx:id="colDebt" text="Nợ hiện tại" prefWidth="100.0"/>
            <TableColumn fx:id="colDiscount" text="CK (%)" prefWidth="60.0"/>
        </columns>
    </TableView>

    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Hủy bỏ" onAction="#onCancel" />
        <Button text="Chọn khách hàng (Enter)" onAction="#onSelect" styleClass="btn-success"/>
    </HBox>
</VBox>
