<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grocerypos.ui.controllers.pos.POSController" style="-fx-background-color: #f4f7f6;">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

    <!-- TOP: Search & Customer Info -->
    <top>
        <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/></padding>
            <BorderPane.margin><Insets bottom="10.0"/></BorderPane.margin>
            
            <VBox spacing="5">
                <Label text="QUÉT MÃ VẠCH (F1)" textFill="#7f8c8d"><font><Font size="10.0"/></font></Label>
                <TextField fx:id="barcodeField" prefWidth="250.0" promptText="Quét hoặc nhập mã..." style="-fx-font-size: 14px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="TÌM SẢN PHẨM (F2)" textFill="#7f8c8d"><font><Font size="10.0"/></font></Label>
                <TextField fx:id="searchField" prefWidth="250.0" promptText="Nhập tên sản phẩm..." style="-fx-font-size: 14px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER_RIGHT" spacing="5">
                <Label fx:id="customerLabel" text="Khách vãng lai" textFill="#2c3e50">
                    <font><Font name="System Bold" size="16.0"/></font>
                </Label>
                <HBox spacing="5">
                    <Button text="Tìm khách (F3)" onAction="#onSelectCustomer" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                    <Button text="Làm mới (F5)" onAction="#onCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </HBox>
    </top>

    <!-- CENTER: Interactive Cart Table -->
    <center>
        <VBox style="-fx-background-color: white; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colIndex" text="#" prefWidth="40.0" />
                    <TableColumn fx:id="colName" text="Sản phẩm" prefWidth="280.0" />
                    <TableColumn fx:id="colQuantity" text="Số lượng" prefWidth="150.0" />
                    <TableColumn fx:id="colPrice" text="Đơn giá" prefWidth="120.0" />
                    <TableColumn fx:id="colDiscount" text="Giảm giá" prefWidth="100.0" />
                    <TableColumn fx:id="colTotal" text="Thành tiền" prefWidth="130.0" />
                    <TableColumn fx:id="colActions" text="" prefWidth="60.0" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- RIGHT: Payment Panel -->
    <right>
        <VBox spacing="20.0" prefWidth="380.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
            <BorderPane.margin><Insets left="15.0"/></BorderPane.margin>

            <Label text="THANH TOÁN">
                <font><Font name="System Bold" size="20.0"/></font>
            </Label>
            <Separator />

            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Tổng tiền hàng:" textFill="#7f8c8d"/><Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="subtotalLabel" text="0 đ"><font><Font size="16.0"/></font></Label>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Giảm giá (KM + Khách):" textFill="#7f8c8d"/><Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="discountLabel" text="0 đ" textFill="#e74c3c"><font><Font size="16.0"/></font></Label>
                </HBox>
                <Separator />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Label text="TỔNG CỘNG" textFill="#2c3e50"><font><Font name="System Bold" size="14.0"/></font></Label>
                    <Label fx:id="totalAmountLabel" text="0 đ" textFill="#2ecc71">
                        <font><Font name="System Bold" size="36.0"/></font>
                    </Label>
                </VBox>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-background-radius: 5;">
                <Label text="TIỀN KHÁCH ĐƯA (Enter)" textFill="#7f8c8d"><font><Font name="System Bold" size="11.0"/></font></Label>
                <TextField fx:id="amountPaidField" alignment="CENTER_RIGHT" prefHeight="50.0" promptText="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="TIỀN THỐI:" textFill="#7f8c8d"><font><Font name="System Bold" size="14.0"/></font></Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="changeAmountLabel" text="0 đ" textFill="#f39c12">
                        <font><Font name="System Bold" size="20.0"/></font>
                    </Label>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnCheckout" onAction="#onCheckout" text="XÁC NHẬN THANH TOÁN (F12)" prefHeight="80.0" maxWidth="Infinity" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            
            <HBox spacing="10">
                <Button onAction="#onCancel" text="HỦY ĐƠN" prefHeight="40.0" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                <Button onAction="#onPrintPreview" text="IN THỬ" prefHeight="40.0" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </right>
</BorderPane>
