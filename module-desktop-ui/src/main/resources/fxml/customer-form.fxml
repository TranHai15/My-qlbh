<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<VBox prefWidth="700.0" style="-fx-background-color: white; -fx-background-radius: 20;" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.grocerypos.ui.controllers.CustomerFormController">
    
    <stylesheets>
        <URL value="@../css/camellia-theme.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #FDF1F5; -fx-padding: 0 40; -fx-background-radius: 20 20 0 0;">
        <Label fx:id="titleLabel" text="Thông Tin Khách Hàng" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #D83367;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="👥 Hội viên" style="-fx-text-fill: #D83367; -fx-opacity: 0.5; -fx-font-weight: bold;" />
    </HBox>

    <!-- Body -->
    <VBox spacing="25.0" style="-fx-padding: 40;">
        <GridPane hgap="30.0" vgap="25.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
            </columnConstraints>

            <Label text="Họ và tên *" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
            <TextField fx:id="nameField" promptText="Nhập tên khách hàng..." prefHeight="45.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Số điện thoại *" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
            <TextField fx:id="phoneField" promptText="Dùng để tích điểm..." prefHeight="45.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Địa chỉ" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
            <TextField fx:id="addressField" promptText="Số nhà, tên đường..." prefHeight="45.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Ưu đãi cố định:" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
            <Label text="1% (Mặc định cho toàn bộ hội viên)" style="-fx-text-fill: #16A085; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Ghi chú" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
            <TextArea fx:id="notesField" promptText="Thông tin bổ sung về khách hàng..." prefHeight="100.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        </GridPane>
    </VBox>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 0 40 40 40;">
        <CheckBox fx:id="activeCheck" text="Đang hoạt động" selected="true" style="-fx-font-size: 14;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleCancel" text="Hủy bỏ" style="-fx-background-color: transparent; -fx-text-fill: #95A5A6; -fx-cursor: hand;" prefWidth="100.0" />
        <Button onAction="#handleSave" text="Lưu Hội Viên" styleClass="btn-primary" prefHeight="50.0" prefWidth="200.0" />
    </HBox>
</VBox>
