<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<VBox prefWidth="700.0" style="-fx-background-color: white; -fx-background-radius: 20;" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.grocerypos.ui.controllers.CategoryFormController">
    
    <stylesheets>
        <URL value="@../css/camellia-theme.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #FDF1F5; -fx-padding: 0 40; -fx-background-radius: 20 20 0 0;">
        <Label fx:id="titleLabel" text="Thông Tin Danh Mục" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #D83367;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="📂 Phân loại" style="-fx-text-fill: #D83367; -fx-opacity: 0.5; -fx-font-weight: bold;" />
    </HBox>

    <!-- Body -->
    <VBox spacing="25.0" style="-fx-padding: 40;">
        <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
            </columnConstraints>

            <Label text="Tên danh mục *" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
            <TextField fx:id="nameField" promptText="VD: Đồ uống, Thực phẩm khô..." prefHeight="45.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Danh mục cha" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="parentCombo" promptText="-- Chọn danh mục gốc (nếu có) --" prefHeight="45.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Mô tả" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
            <TextArea fx:id="descField" promptText="Mô tả ngắn gọn về nhóm hàng này..." prefHeight="100.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Biểu tượng / Ảnh" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
            <HBox spacing="15.0" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <StackPane prefHeight="100.0" prefWidth="100.0" style="-fx-border-color: #ECF0F1; -fx-border-width: 2; -fx-border-style: dashed; -fx-border-radius: 10;">
                    <ImageView fx:id="categoryImageView" fitHeight="90.0" fitWidth="90.0" pickOnBounds="true" preserveRatio="true" />
                </StackPane>
                <Button onAction="#handleChooseImage" text="Chọn ảnh" style="-fx-background-color: #FDF1F5; -fx-text-fill: #D83367; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </GridPane>
    </VBox>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 0 40 40 40;">
        <CheckBox fx:id="activeCheck" text="Cho phép hiển thị" selected="true" style="-fx-font-size: 14;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleCancel" text="Hủy bỏ" style="-fx-background-color: transparent; -fx-text-fill: #95A5A6; -fx-cursor: hand;" prefWidth="100.0" />
        <Button onAction="#handleSave" text="Lưu Danh Mục" styleClass="btn-primary" prefHeight="50.0" prefWidth="200.0" />
    </HBox>
</VBox>
