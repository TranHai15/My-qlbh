<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<StackPane prefWidth="800.0" prefHeight="600.0" style="-fx-background-color: #FFF9F9;" 
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.grocerypos.ui.controllers.LoginController">
    
    <stylesheets>
        <URL value="@../css/camellia-theme.css" />
    </stylesheets>

    <!-- Background Decoration -->
    <Pane mouseTransparent="true">
        <Label text="&#x1F338;" layoutX="50.0" layoutY="50.0" style="-fx-font-size: 40; -fx-opacity: 0.2;"/>
        <Label text="&#x1F338;" layoutX="700.0" layoutY="500.0" style="-fx-font-size: 60; -fx-opacity: 0.1;"/>
        <Label text="&#x1F338;" layoutX="650.0" layoutY="80.0" style="-fx-font-size: 30; -fx-opacity: 0.15;"/>
    </Pane>

    <VBox alignment="CENTER" spacing="30.0" maxWidth="400.0" maxHeight="500.0" styleClass="card">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Camellia" styleClass="app-title" />
            <Label text="Thanh xuân &amp; Sự tử tế" textFill="#A88181">
                <font><Font name="System Italic" size="14.0" /></font>
            </Label>
        </VBox>
        
        <VBox spacing="15.0">
            <Label text="Đăng nhập" textFill="#5D4037" style="-fx-font-weight: bold;"/>
            <TextField fx:id="usernameField" promptText="Tên đăng nhập" prefHeight="45.0" />
            <PasswordField fx:id="passwordField" promptText="Mật khẩu" prefHeight="45.0" />
        </VBox>

        <Button fx:id="loginButton" text="Đăng Nhập" onAction="#handleLogin"
                prefHeight="50.0" prefWidth="Infinity" styleClass="btn-primary" />

        <Label fx:id="statusLabel" textFill="#D83367" />
    </VBox>
</StackPane>
